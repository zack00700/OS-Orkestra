# ═══════════════════════════════════════════════════════
# OS HubLine — Configuration (.env)
# ═══════════════════════════════════════════════════════

# App
APP_NAME=OS HubLine
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# Database — Décommenter la ligne correspondant à votre moteur :
# Le driver async est ajouté automatiquement, pas besoin de +asyncpg etc.
#
# PostgreSQL (défaut)
DATABASE_URL=postgresql://hubline:hubline@localhost:5432/hubline
#
# SQL Server (LIMIT → OFFSET FETCH automatique, NVARCHAR(MAX) pour JSON/TEXT)
# DATABASE_URL=mssql://sa:YourStrong!Passw0rd@localhost:1433/hubline
#
# MySQL
# DATABASE_URL=mysql://hubline:hubline@localhost:3306/hubline
#
# MariaDB
# DATABASE_URL=mariadb://hubline:hubline@localhost:3306/hubline
#
# SQLite (dev/test uniquement)
# DATABASE_URL=sqlite:///./hubline.db
#
# Oracle
# DATABASE_URL=oracle://hubline:hubline@localhost:1521/XEPDB1

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=your-jwt-secret-change-me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Azure AD (Microsoft Entra ID)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# CRM Dynamics 365
DYNAMICS_BASE_URL=https://your-org.crm4.dynamics.com
DYNAMICS_CLIENT_ID=
DYNAMICS_CLIENT_SECRET=
DYNAMICS_TENANT_ID=

# CRM Salesforce (alternative)
SALESFORCE_BASE_URL=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@opensid.com
