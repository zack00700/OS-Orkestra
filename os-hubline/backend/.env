# ═══════════════════════════════════════════════════════
# OS HubLine — Configuration
# Copié depuis .env.example — prêt à l'emploi
# ═══════════════════════════════════════════════════════

# App
APP_NAME=OS HubLine
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production-abc123

# ─── Base de données ────────────────────────────────────
# Par défaut : SQLite (aucune installation requise, idéal pour démarrer)
DATABASE_URL=sqlite:///./hubline.db
#
# Décommenter UNE des lignes ci-dessous pour changer de moteur :
# DATABASE_URL=postgresql://hubline:hubline@localhost:5432/hubline
# DATABASE_URL=mssql://sa:YourStrong!Passw0rd@localhost:1433/hubline
# DATABASE_URL=mysql://hubline:hubline@localhost:3306/hubline

# Redis (nécessaire uniquement si tu lances Celery)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=dev-jwt-secret-change-me-in-prod
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Azure AD (laisser vide pour l'instant)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# CRM Dynamics 365 (laisser vide pour l'instant)
DYNAMICS_BASE_URL=
DYNAMICS_CLIENT_ID=
DYNAMICS_CLIENT_SECRET=
DYNAMICS_TENANT_ID=

# CRM Salesforce (laisser vide pour l'instant)
SALESFORCE_BASE_URL=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# WhatsApp Business API (laisser vide pour l'instant)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# SMTP (laisser vide pour l'instant)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@opensid.com
